# Vordi signing + notarization credentials.
#
# Copy this file to `.env.signing` (which is gitignored) and fill in the values.
# Then run `./scripts/ship.sh v0.3.0` to build a signed + notarized DMG.
#
# Where to find each value is documented in scripts/README_SIGNING.md.
# ---------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# REQUIRED for signing
# -----------------------------------------------------------------------------

# Full codesigning identity string. Must match the cert in your Keychain exactly.
# Find it with: security find-identity -v -p codesigning | grep "Developer ID Application"
# Format:       "Developer ID Application: <NAME> (<TEAM_ID>)"
export DEVELOPER_ID="Developer ID Application: Shopsense Retail Technologies Limited (XXXXXXXXXX)"

# -----------------------------------------------------------------------------
# REQUIRED for notarization — pick ONE of the two approaches below.
# -----------------------------------------------------------------------------

# --- Approach A: Keychain profile (recommended, more secure) --------------
#
# One-time setup, run this in your shell:
#   xcrun notarytool store-credentials "vordi-notarize" \
#     --apple-id "you@example.com" \
#     --team-id "XXXXXXXXXX" \
#     --password "abcd-efgh-ijkl-mnop"
#
# Then uncomment this line and comment out Approach B:
# export NOTARIZE_KEYCHAIN_PROFILE="vordi-notarize"

# --- Approach B: Plain env vars (simpler, less secure) --------------------

# Apple ID email tied to the Developer Program team
export NOTARIZE_APPLE_ID="you@example.com"

# 10-character team ID — find at https://developer.apple.com/account → Membership details
export NOTARIZE_TEAM_ID="XXXXXXXXXX"

# App-specific password — generate at https://appleid.apple.com → App-Specific Passwords
# Format: "abcd-efgh-ijkl-mnop"
export NOTARIZE_PASSWORD="xxxx-xxxx-xxxx-xxxx"
